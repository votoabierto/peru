# VotoClaro — Environment Variables
# Copy to .env.local and fill in your Supabase project credentials

# Public (used on client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private (server-side seed scripts only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin panel (/admin/contribuciones)
ADMIN_PASSWORD=your-admin-password-here

# GitHub API (for creating issues from approved contributions)
GITHUB_TOKEN=your-github-token-here

# Quiz anonymous storage
QUIZ_DEDUP_SALT=your-random-secret-string-here
QUIZ_RELEASE_THRESHOLD=1000
